## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# JetBrains Rider
.idea/
*.sln.iml
.idea/
.idea
**/.idea/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg

# NuGet Symbol Packages
*.snupkg

# Others
~$*
*~
CodeCoverage/

# MSBuild Binary and Structured Log
*.binlog

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# ========================
# Secrets & Configuration
# ========================

# User secrets (ASP.NET Core - never commit these)
**/secrets.json
appsettings.Development.json
appsettings.Local.json

# Connection strings and API keys if stored separately
appsettings.Production.json

# .env files (if used for local dev)
.env
.env.*

# ========================
# JetBrains Rider
# ========================

.idea/
*.sln.iml

# Rider shelf and local history
.idea/shelf/
.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/dictionaries/
.idea/httpRequests/

# ========================
# EF Core
# ========================

# If you generate SQL scripts locally during development
*.sql

# ========================
# Linux / OS
# ========================

*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ========================
# Uploads & User Content
# ========================

# If articles allow file attachments in the future
wwwroot/uploads/

# ========================
# Local Dev Tooling
# ========================

# dotnet-tools local config (keep the manifest, not the binaries)
.config/
